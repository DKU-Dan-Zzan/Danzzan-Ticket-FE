# 백엔드 타겟을 선택합니다. 미설정 시 serverdb가 기본값입니다.
# serverdb -> http://<host>:8080
# compose  -> http://<host>:8081
VITE_BACKEND_TARGET=serverdb

# 메인 API의 기본 URL을 직접 지정합니다. 설정 시 VITE_BACKEND_TARGET보다 우선합니다.
VITE_API_BASE_URL=

# (선택) 메인 API와 다를 때만 티켓팅 API 기본 URL을 지정합니다.
VITE_TICKETING_API_BASE_URL=

# API 모드를 설정합니다. 실제 API를 사용하려면 "live", 모의 데이터를 사용하려면 "mock"으로 설정합니다.
VITE_API_MODE=live

# 개발 및 테스트 목적의 접근 토큰이 필요한 경우 설정합니다.
VITE_DEV_ACCESS_TOKEN=
