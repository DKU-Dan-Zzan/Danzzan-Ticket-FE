{
  "includeDirs": [
    "src"
  ],
  "extensions": [
    ".ts",
    ".tsx"
  ],
  "excludeDirs": [
    "node_modules",
    "dist",
    ".next",
    "build",
    "coverage",
    ".turbo",
    "storybook-static",
    "src/api",
    "src/api/generated"
  ],
  "inlineAllowDirective": "color-allow:",
  "tailwindColorPrefixes": [
    "bg",
    "text",
    "border",
    "ring",
    "from",
    "to",
    "via",
    "stroke",
    "fill"
  ],
  "bannedTailwindColorScales": [
    "blue",
    "red",
    "green",
    "emerald",
    "cyan",
    "indigo",
    "sky",
    "teal",
    "violet",
    "purple",
    "fuchsia",
    "pink",
    "rose",
    "amber",
    "orange",
    "yellow",
    "lime",
    "slate",
    "gray",
    "neutral",
    "stone",
    "zinc"
  ],
  "allowFiles": [
    {
      "path": "src/components/common/ui/chart.tsx",
      "reason": "Recharts 셀렉터의 기본 SVG stroke/fill 매칭 문자열은 라이브러리 스펙에 의존합니다."
    },
    {
      "path": "src/components/admin/WristbandOperationScreen.tsx",
      "reason": "관리자 화면의 상태색 레거시 값 정리 전 임시 허용."
    }
  ]
}
